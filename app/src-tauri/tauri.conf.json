{
  "$schema": "https://schema.tauri.app/config/2",
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/ibnuasyi/Telegram-Drive-GPG/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4MDgwQzg5NzM3QTEwMUQKUldRZEVIcHppUXdJNkRtWDBiTWY1SU82aWtVYU1PcU5FbFdWdG1HdjFzckRYelRYTXdTbzZORkgK"
    }
  },
  "productName": "Cicem Drive",
  "version": "0.9.6",
  "identifier": "net.cicem.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cicem Drive",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: http://localhost:* https://asset.localhost http://asset.localhost; media-src 'self' blob: http://localhost:*; img-src 'self' data: blob: asset: https: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' blob: https:; frame-src 'self' blob: https:; worker-src 'self' blob:;",
      "capabilities": [
        "default",
        "mobile-only"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
